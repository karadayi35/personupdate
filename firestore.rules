rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "aalikirmizigul89@gmail.com" ||
        (exists(/databases/$(database)/documents/employees/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/employees/$(request.auth.uid)).data.role == 'admin')
      );
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.employeeId;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Employees Collection
    match /employees/{employeeId} {
      allow read: if isAuthenticated() && (resource.data.authUid == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow update: if isAdmin() || (isAuthenticated() && resource.data.authUid == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['avatar', 'updatedAt']));
      allow delete: if isAdmin();
    }

    // Attendance Records
    match /attendance_records/{recordId} {
      allow read: if isAuthenticated() && (resource.data.employeeId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && (request.resource.data.employeeId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Branches
    match /branches/{branchId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Leave Records
    match /leave_records/{recordId} {
      allow read: if isAuthenticated() && (resource.data.employeeId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && (request.resource.data.employeeId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Leave Balances
    match /leave_balances/{balanceId} {
      allow read: if isAuthenticated() && (resource.data.employeeId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // Leave Change Logs
    match /leave_change_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    // Leave Requests
    match /leave_requests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.employeeId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.employeeId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Licenses
    match /licenses/{licenseId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only manageable via Firebase Console or special script
    }

    // Settings
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Shifts
    match /shifts/{shiftId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Employee Shift Assignments
    match /employee_shift_assignments/{assignmentId} {
      allow read: if isAuthenticated() && (resource.data.employeeId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // Leaves
    match /leaves/{leaveId} {
      allow read: if isAuthenticated() && (resource.data.employeeId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.employeeId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /leave_records/{leaveId} {
      allow read: if isAuthenticated() && (resource.data.employeeId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.employeeId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /leave_balances/{balanceId} {
      allow read: if isAuthenticated() && (resource.data.employeeId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    match /leave_change_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    match /hourly_leaves/{leaveId} {
      allow read: if isAuthenticated() && (resource.data.employeeId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.employeeId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /hourly_leave_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // Breaks
    match /break_records/{recordId} {
      allow read: if isAuthenticated() && (resource.data.employeeId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.employeeId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Shift Overrides
    match /shift_overrides/{overrideId} {
      allow read: if isAuthenticated() && (resource.data.employeeId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // Auto Report Configs
    match /auto_report_configs/{configId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Auto Report Logs
    match /auto_report_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // Salary Configs
    match /salary_configs/{configId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Salary Records
    match /salary_records/{recordId} {
      allow read: if isAuthenticated() && (resource.data.employeeId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Email Logs
    match /email_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // Branch Breaks
    match /branch_breaks/{breakId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Employee Break Overrides
    match /employee_break_overrides/{overrideId} {
      allow read: if isAuthenticated() && (resource.data.employeeId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
